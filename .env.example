# ============================================================
#  OAuth2 API credentials  (RECOMMENDED for scheduled/unattended runs)
#  YouGov issues client_id/client_secret once; then the script runs hands-off.
#  If these are set, the script authenticates via OAuth2 and ignores the
#  email/password below.
# ============================================================
YOUGOV_CLIENT_ID=
YOUGOV_CLIENT_SECRET=
YOUGOV_TOKEN_URL=https://login.yougov.com/oauth/token
YOUGOV_SCOPE=brandindex
# client_credentials (preferred, fully unattended) or refresh_token
YOUGOV_GRANT_TYPE=client_credentials
# Only needed if YOUGOV_GRANT_TYPE=refresh_token:
YOUGOV_REFRESH_TOKEN=
# How to send client creds to the token endpoint: body (default) or basic
YOUGOV_CLIENT_AUTH=body

# ============================================================
#  Email / password  (fallback; not API-authorized on accounts without API access)
# ============================================================
YOUGOV_EMAIL=
YOUGOV_PASSWORD=
YOUGOV_BASE_URL=https://api.brandindex.com

# ============================================================
#  BigQuery destination
# ============================================================
BQ_PROJECT=your-gcp-project-id
BQ_DATASET=your_dataset
BQ_TABLE=brandindex_long
BQ_LOCATION=US
# WRITE_TRUNCATE (replace each run) or WRITE_APPEND (add rows)
BQ_WRITE_DISPOSITION=WRITE_TRUNCATE

# Path to a GCP service-account JSON key (recommended for scheduled runs).
# Leave blank to use Application Default Credentials (gcloud auth application-default login).
GOOGLE_APPLICATION_CREDENTIALS=
